{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "haguar-coffee",
    "compatibility_date": "2026-07-15",
    "workers_dev": true,
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    },
    "routes": [
        {
            "pattern": "coffee.haguar.co",
            "custom_domain": true
        }
    ]
}